NODE_ENV=production
DB_CLIENT=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
PG_SEARCH_PATH=app,public
PGSSL=true
JWT_SECRET=replace-with-a-unique-secret-at-least-32-characters
CORS_ORIGIN=https://your-vercel-project.vercel.app
API_URL=https://your-vercel-project.vercel.app
TRUST_PROXY=1
UPLOAD_DIR=/tmp/uploads
SCANNER_IMPORT_DIR=/tmp/scanner-inbox
STAFF_DEFAULT_PERMISSIONS=patients:read,patients:write,records:read,records:write,calendar:read,calendar:write,documents:read,documents:write
REQUIRE_PRODUCTION_READY=true
INITIAL_DIRECTOR_PASSWORD=replace-with-strong-director-password
INITIAL_STAFF_PASSWORD=replace-with-strong-staff-password
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
