NODE_ENV=production
PORT=3000
SQLITE_DB_PATH=./data/drosa.sqlite
BACKUP_DIR=./backups
UPLOAD_DIR=./uploads
SCANNER_IMPORT_DIR=./data/scanner-inbox
API_URL=https://drrosa.example.com
CORS_ORIGIN=https://drrosa.example.com
TRUST_PROXY=loopback
REQUIRE_PRODUCTION_READY=true
JWT_SECRET=replace-with-unique-secret-at-least-32-characters
BACKUP_ENCRYPTION_KEY=replace-with-different-backup-key-at-least-32-characters
STAFF_DEFAULT_PERMISSIONS=patients:read,patients:write,records:read,records:write,calendar:read,calendar:write,documents:read,documents:write
INITIAL_DIRECTOR_PASSWORD=replace-with-strong-director-password
INITIAL_STAFF_PASSWORD=replace-with-strong-staff-password
