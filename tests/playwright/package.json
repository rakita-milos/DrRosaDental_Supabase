{
  "name": "drrosa-playwright-smoke-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Automated Playwright smoke tests for the Dr Rosa web app.",
  "scripts": {
    "test": "node scripts/run-with-server.js",
    "test:smoke": "node scripts/run-with-server.js tests/smoke.spec.js tests/app-smoke.spec.js",
    "test:integration": "node scripts/run-with-server.js tests/role-integration.e2e.spec.js",
    "test:exports": "node scripts/run-with-server.js tests/reports-export.e2e.spec.js",
    "test:regression": "node scripts/run-with-server.js tests/regression.e2e.spec.js",
    "test:headed": "node scripts/run-with-server.js --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
